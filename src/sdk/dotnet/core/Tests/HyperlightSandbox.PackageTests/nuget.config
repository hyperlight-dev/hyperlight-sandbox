<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear inherited sources to ensure we only use local + nuget.org -->
    <clear />
    <!-- Local dist folder with freshly built NuGet packages -->
    <add key="local" value="../../../../../../dist/dotnetsdk" />
    <!-- NuGet.org for test dependencies (xunit etc.) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
