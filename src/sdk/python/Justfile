    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/python_filesystem_demo.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_basics.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_network_demo.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_filesystem_demo.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_basics.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_network_demo.py
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_filesystem_demo.py

python-sandbox-benchmark: (python-build "release")
    {{ wit-world }} uv run python {{repo-root}}/src/sdk/python/core/examples/benchmark.py

#### CLEAN ####

clean:
    rm -rf {{repo-root}}/src/sdk/python/wasm_backend/target
    rm -rf {{repo-root}}/src/sdk/python/hyperlight_js_backend/target

#### LINT / FORMAT ####

lint:
    uv run ruff check {{repo-root}}/src/sdk/python {{repo-root}}/examples

fmt:
    uv run ruff format {{repo-root}}/src/sdk/python {{repo-root}}/examples
    uv run ruff check --fix {{repo-root}}/src/sdk/python {{repo-root}}/examples

fmt-check:
    uv run ruff format --check {{repo-root}}/src/sdk/python {{repo-root}}/examples
    uv run ruff check {{repo-root}}/src/sdk/python {{repo-root}}/examples

#### TESTS ####

python-test: python-build
    uv run python -m unittest discover -s {{repo-root}}/src/sdk/python/core/tests -p 'test_*.py' -v

python-fuzz seconds="60": python-build
    uv run --package hyperlight-sandbox --extra dev python {{repo-root}}/src/sdk/python/core/tests/fuzz_tool_dispatch.py -max_total_time={{seconds}}
