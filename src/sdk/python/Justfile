set windows-shell := ["pwsh", "-NoLogo", "-Command"]

repo-root := invocation_directory_native()
export WIT_WORLD := repo-root + "/src/wasm_sandbox/wit/sandbox-world.wasm"
rmrf := if os() == "windows" { "Remove-Item -Recurse -Force -ErrorAction SilentlyContinue" } else { "rm -rf" }
mkdirp := if os() == "windows" { "New-Item -ItemType Directory -Force" } else { "mkdir -p" }

dist-root := repo-root + "/dist/pythonsdk"
core-dist := dist-root + "/core"
wasm-wheels := dist-root + "/wasm_backend"
hyperlight-js-wheels := dist-root + "/hyperlight_js_backend"
python-guest-dist := dist-root + "/python_guest"
javascript-guest-dist := dist-root + "/javascript_guest"

#### BUILD ####

# Copy pre-built guest binaries (.aot/.wasm) from the wasm_sandbox build
# into the Python guest packages so they can be bundled into wheels.
# Requires `just wasm build` to have run first.
python-sync-guest-resources:
    {{mkdirp}} {{repo-root}}/src/sdk/python/wasm_guests/python_guest/python_guest/resources
    {{mkdirp}} {{repo-root}}/src/sdk/python/wasm_guests/javascript_guest/javascript_guest/resources
    cp {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.aot {{repo-root}}/src/sdk/python/wasm_guests/python_guest/python_guest/resources/python-sandbox.aot
    cp {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.wasm {{repo-root}}/src/sdk/python/wasm_guests/python_guest/python_guest/resources/python-sandbox.wasm
    cp {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.aot {{repo-root}}/src/sdk/python/wasm_guests/javascript_guest/javascript_guest/resources/js-sandbox.aot
    cp {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.wasm {{repo-root}}/src/sdk/python/wasm_guests/javascript_guest/javascript_guest/resources/js-sandbox.wasm

# Install pure Python dependencies from the lockfile into the local venv.
# Skips the two Rust backend packages — those are compiled and installed
# separately by `python-install-backends` via `maturin develop`.
python-sync-env:
    uv sync --frozen --inexact --no-install-package hyperlight-sandbox-backend-wasm --no-install-package hyperlight-sandbox-backend-hyperlight-js

# Install maturin backends into the local venv for development (maturin develop).
# This compiles the Rust backend crates and installs them as editable packages
# in the local venv so you can `import hyperlight_sandbox` directly.
# For distributable wheels, use `python-dist` (maturin build) instead.
# Use `just python python-build` for debug, `just python python-build release` for release.
python-install-backends profile="debug":
    -{{ if profile == "release" { rmrf + " " + repo-root + "/target/release/build/hyperlight-wasm-*" } else { "" } }}
    -{{ if profile == "release" { rmrf + " " + repo-root + "/target/release/.fingerprint/hyperlight-wasm-*" } else { "" } }}
    -{{ if profile == "release" { rmrf + " " + repo-root + "/target/release/build/hyperlight-js-*" } else { "" } }}
    -{{ if profile == "release" { rmrf + " " + repo-root + "/target/release/.fingerprint/hyperlight-js-*" } else { "" } }}
    cd {{repo-root}}/src/sdk/python/wasm_backend && uv run --no-sync maturin develop {{ if profile == "release" { "--release" } else { "" } }}
    cd {{repo-root}}/src/sdk/python/hyperlight_js_backend && uv run --no-sync maturin develop {{ if profile == "release" { "--release" } else { "" } }}

python-build profile="debug": python-sync-guest-resources python-sync-env (python-install-backends profile)

build: python-build

#### DIST / PUBLISH ####

python-dist: python-sync-guest-resources
    -{{rmrf}} {{dist-root}}
    cd {{repo-root}}/src/sdk/python/core && uv run python -m build --outdir {{core-dist}}
    cd {{repo-root}}/src/sdk/python/wasm_backend && uv run maturin build --release --out {{wasm-wheels}}
    cd {{repo-root}}/src/sdk/python/hyperlight_js_backend && uv run maturin build --release --out {{hyperlight-js-wheels}}
    cd {{repo-root}}/src/sdk/python/wasm_guests/python_guest && uv run python -m build --outdir {{python-guest-dist}}
    cd {{repo-root}}/src/sdk/python/wasm_guests/javascript_guest && uv run python -m build --outdir {{javascript-guest-dist}}

# Build only the platform-specific maturin backend wheels.
# Used by CI to produce Windows wheels without needing guest binaries.
# Requires sandbox-world.wasm to exist (run `just wasm guest-compile-wit` first).
python-dist-backends: python-sync-env
    -{{rmrf}} {{wasm-wheels}}
    -{{rmrf}} {{hyperlight-js-wheels}}
    cd {{repo-root}}/src/sdk/python/wasm_backend && uv run maturin build --release --out {{wasm-wheels}}
    cd {{repo-root}}/src/sdk/python/hyperlight_js_backend && uv run maturin build --release --out {{hyperlight-js-wheels}}

python-publish repository="pypi":
    uv publish {{ if repository != "pypi" { "--publish-url https://test.pypi.org/legacy/" } else { "" } }} {{wasm-wheels}}/*
    uv publish {{ if repository != "pypi" { "--publish-url https://test.pypi.org/legacy/" } else { "" } }} {{hyperlight-js-wheels}}/*
    uv publish {{ if repository != "pypi" { "--publish-url https://test.pypi.org/legacy/" } else { "" } }} {{python-guest-dist}}/*
    uv publish {{ if repository != "pypi" { "--publish-url https://test.pypi.org/legacy/" } else { "" } }} {{javascript-guest-dist}}/*
    uv publish {{ if repository != "pypi" { "--publish-url https://test.pypi.org/legacy/" } else { "" } }} {{core-dist}}/*

# Smoke-test the wheels in dist/pythonsdk/ by installing them into
# isolated environments and running basic tests.
# Requires `just python-dist` (root) to have been run first.
python-wheelhouse-test:
    uv run --no-project --no-index \
        --find-links={{core-dist}} \
        --find-links={{wasm-wheels}} \
        --find-links={{python-guest-dist}} \
        --with "hyperlight-sandbox[wasm,python_guest]" \
        python {{repo-root}}/src/sdk/python/tests/wheelhouse_wasm.py
    uv run --no-project --no-index \
        --find-links={{core-dist}} \
        --find-links={{hyperlight-js-wheels}} \
        --find-links={{javascript-guest-dist}} \
        --with "hyperlight-sandbox[hyperlight_js,javascript_guest]" \
        python {{repo-root}}/src/sdk/python/tests/wheelhouse_js.py

#### EXAMPLES ####

examples: python-build
    uv run python {{repo-root}}/src/sdk/python/core/examples/python_basics.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/python_network_demo.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/python_filesystem_demo.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_basics.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_network_demo.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/javascript_filesystem_demo.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_basics.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_network_demo.py
    uv run python {{repo-root}}/src/sdk/python/core/examples/jswasm_filesystem_demo.py

python-sandbox-benchmark: (python-build "release")
    uv run python {{repo-root}}/src/sdk/python/core/examples/benchmark.py

#### CLEAN ####

clean:
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target
    -{{rmrf}} {{repo-root}}/src/sdk/python/hyperlight_js_backend/target

#### LINT / FORMAT ####

lint:
    uv run ruff check {{repo-root}}/src/sdk/python {{repo-root}}/examples

fmt:
    uv run ruff format {{repo-root}}/src/sdk/python {{repo-root}}/examples
    uv run ruff check --fix {{repo-root}}/src/sdk/python {{repo-root}}/examples

fmt-check:
    uv run ruff format --check {{repo-root}}/src/sdk/python {{repo-root}}/examples
    uv run ruff check {{repo-root}}/src/sdk/python {{repo-root}}/examples

#### TESTS ####

python-test: python-build
    uv run python -m unittest discover -s {{repo-root}}/src/sdk/python/core/tests -p 'test_*.py' -v

python-fuzz seconds="60": python-build
    {{ if os() == "windows" { "echo 'Skipping python fuzz (atheris not available on Windows)'" } else { "uv run --package hyperlight-sandbox --extra dev python " + repo-root + "/src/sdk/python/core/tests/fuzz_tool_dispatch.py -max_total_time=" + seconds } }}
