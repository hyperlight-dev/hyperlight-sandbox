set windows-shell := ["pwsh", "-NoLogo", "-Command"]

default-target := "debug"
repo-root := invocation_directory_native()
export WIT_WORLD := repo-root + "/src/wasm_sandbox/wit/sandbox-world.wasm"
rmrf := if os() == "windows" { "Remove-Item -Recurse -Force -ErrorAction SilentlyContinue" } else { "rm -rf" }

[unix]
ensure-tools:
    @command -v clang >/dev/null 2>&1 || { echo "clang not found — install with: apt install clang or brew install llvm"; exit 1; }
    @command -v wasm-tools >/dev/null 2>&1 || cargo install wasm-tools --locked
    @command -v hyperlight-wasm-aot >/dev/null 2>&1 || \
        cargo install hyperlight-wasm-aot \
            --git https://github.com/jsturtevant/hyperlight-wasm \
            --rev 09b5e8297d827518847c08c8506bf83e85eb89b1

[windows]
ensure-tools:
    if (-not (Get-Command clang -ErrorAction SilentlyContinue)) { Write-Error 'clang not found — install with: winget install LLVM.LLVM'; exit 1 }; \
    if (-not (Get-Command wasm-tools -ErrorAction SilentlyContinue)) { cargo install wasm-tools --locked }; \
    if (-not (Get-Command hyperlight-wasm-aot -ErrorAction SilentlyContinue)) { cargo install hyperlight-wasm-aot --git https://github.com/jsturtevant/hyperlight-wasm --rev 09b5e8297d827518847c08c8506bf83e85eb89b1 }

guest-build-wasm: ensure-tools
    cd {{repo-root}}/src/wasm_sandbox/guests/python && uv run componentize-py \
        -d ../../wit/hyperlight-sandbox.wit -w root \
        componentize sandbox_executor -o python-sandbox.wasm
    wasm-tools strip --all {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.wasm -o {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.wasm

guest-compile-wit: ensure-tools
    wasm-tools component wit {{repo-root}}/src/wasm_sandbox/wit/hyperlight-sandbox.wit -w -o {{repo-root}}/src/wasm_sandbox/wit/sandbox-world.wasm
    just _invalidate-wit-caches

# Invalidate cargo caches that embed the WIT signature.
# Without this, cargo won't detect that sandbox-world.wasm changed
# and SDKs will fail at runtime with "vector parameter missing length".
_invalidate-wit-caches:
    -{{rmrf}} {{repo-root}}/target/hyperlight-wasm-runtime
    -{{rmrf}} {{repo-root}}/target/hyperlight-js-runtime
    -{{rmrf}} {{repo-root}}/target/debug/build/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/target/debug/.fingerprint/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/target/release/build/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/target/release/.fingerprint/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/target/debug/build/hyperlight-js-*
    -{{rmrf}} {{repo-root}}/target/debug/.fingerprint/hyperlight-js-*
    -{{rmrf}} {{repo-root}}/target/release/build/hyperlight-js-*
    -{{rmrf}} {{repo-root}}/target/release/.fingerprint/hyperlight-js-*
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target/hyperlight-wasm-runtime
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target/debug/build/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target/debug/.fingerprint/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target/release/build/hyperlight-wasm-*
    -{{rmrf}} {{repo-root}}/src/sdk/python/wasm_backend/target/release/.fingerprint/hyperlight-wasm-*

guest-build-aot target=default-target: guest-build-wasm ensure-tools
    hyperlight-wasm-aot compile --component \
        {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.wasm {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.aot

guest-build target=default-target: (guest-build-wasm) (guest-compile-wit) (guest-build-aot target)

js-guest-build-wasm: (js-guest-install)
    cd {{repo-root}}/src/wasm_sandbox/guests/javascript && npm run build

js-guest-build-aot: js-guest-build-wasm ensure-tools
    hyperlight-wasm-aot compile --component \
        {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.wasm {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.aot

js-guest-build: js-guest-build-wasm js-guest-build-aot

js-guest-install:
    cd {{repo-root}}/src/wasm_sandbox/guests/javascript && npm install

build target=default-target: (guest-build target) (js-guest-build)
    cargo build --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }}

#### EXAMPLES ####

examples target=default-target:
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example python_basics
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example python_network_demo
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example python_filesystem_demo
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example js_basics
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example js_network_demo
    cargo run --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --example js_filesystem_demo

#### TESTS ####

test target=default-target:
    cargo test --manifest-path {{repo-root}}/src/wasm_sandbox/Cargo.toml --profile={{ if target == "debug" {"dev"} else { target } }} --test http_wasm_integration -- --nocapture

lint:
    cargo clippy -p hyperlight-wasm-sandbox --all-targets -- -D warnings

#### CLEAN ####

guest-clean:
    -{{rmrf}} {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.wasm
    -{{rmrf}} {{repo-root}}/src/wasm_sandbox/guests/python/python-sandbox.aot
    -{{rmrf}} {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.wasm
    -{{rmrf}} {{repo-root}}/src/wasm_sandbox/guests/javascript/js-sandbox.aot

clean: guest-clean
    -{{rmrf}} {{repo-root}}/target/hyperlight-wasm-runtime
    -{{rmrf}} {{repo-root}}/target/hyperlight-js-runtime
